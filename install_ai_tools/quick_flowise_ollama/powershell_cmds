#############
# Script: AA
#############
# The folowing script does two things:
#   1. Creates a folder 'd:\aiExamples\crewaiModels'
#      and then downloads all files and folders from here
#      https://github.com/harnalashok/LLMs/tree/main/crewaiModels
#  2. Copies all files from 'd:\aiExamples\crewaiModels' to
#     WSL ubuntu: /home/ashok/Documents/crewaiModels 
#  3. Ubuntu terminal must remain open for the complete script to work.
#
#
# Open powershell, copy and paste all the following
#  of 'script AA' at one go in the powershell terminal. 
#   UBUNTU TERMINAL MUST ALSO BE OPEN.
############

#  Downloads github folder 'crewaiModels' using command line



cd d:\
$null = New-Item -Path "d:\aiExamples" -ItemType Directory -Force
Remove-Item -Path "d:\aiExamples\crewaiModels" -Recurse -Force -ErrorAction Ignore

cd "d:\aiExamples"


git init
git remote add origin https://github.com/harnalashok/LLMs.git
git sparse-checkout init --cone
git sparse-checkout set crewaiModels
git pull origin main
Get-ChildItem -Path . -Depth 0 | Where-Object { $_.Name -ne 'crewaimodels' } | Remove-Item  -Recurse  -Force
Remove-Item -Path "d:\aiExamples\.git" -Recurse -Force

# 1. Define where you want to move the files (Change this path if needed)
$Destination = "d:\"

# 2. Move all files and subfolders out of aiExamples
Get-ChildItem -Path "d:\aiExamples\*" | Move-Item -Destination $Destination -Force

# 3. Remove the empty aiExamples folder
Remove-Item -Path "d:\aiExamples" -Force


cd "d:\"

# Copy this crewaiModels folder to Ubuntu-22.04--Documents/crewaiModels
# Existing folder is first deleted

$wslPath = "\\wsl.localhost\Ubuntu-22.04\home\ashok\Documents\crewaiModels"
if (Test-Path $wslPath) { Remove-Item -Path $wslPath -Recurse -Force }
Copy-Item -Path "d:\crewaiModels" -Destination "\\wsl.localhost\Ubuntu-22.04\home\ashok\Documents\" -Recurse -Force
cd "d:\"

